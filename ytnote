#!/usr/bin/env python3
"""
ytnote — turn a YouTube video into a timestamped transcript + AI research notes.

Pipeline:
  url -> yt-dlp metadata
      -> transcript (yt-dlp subtitles first, whisper.cpp fallback)
      -> clean [HH:MM:SS] markdown
      -> (optional) research notes via the `claude` CLI

Zero third-party deps. Needs on PATH: yt-dlp, ffmpeg, and (for fallback) whisper, claude.
"""

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
from datetime import date
from pathlib import Path

WHISPER_MODEL = os.environ.get(
    "YTNOTE_WHISPER_MODEL",
    str(Path.home() / ".local/share/whisper/models/ggml-large-v3-turbo.bin"),
)
PARAKEET_MODEL = os.environ.get(
    "YTNOTE_PARAKEET_MODEL",
    str(Path.home() / ".local/share/whisper/models/ggml-parakeet-tdt-0.6b-v3-f16.bin"),
)


def die(msg, code=1):
    print(f"ytnote: {msg}", file=sys.stderr)
    sys.exit(code)


def info(msg):
    print(f"ytnote: {msg}", file=sys.stderr)


def need(tool):
    if not shutil.which(tool):
        die(f"`{tool}` not found on PATH")


def run(cmd, **kw):
    return subprocess.run(cmd, **kw)


# ── metadata ──────────────────────────────────────────────────────────────────
def fetch_meta(url):
    info("fetching video metadata...")
    p = run(
        ["yt-dlp", "-J", "--no-warnings", "--skip-download", url],
        capture_output=True, text=True,
    )
    if p.returncode != 0:
        die(f"yt-dlp could not read the URL\n{p.stderr.strip()}")
    d = json.loads(p.stdout)
    return {
        "id": d["id"],
        "title": d.get("title", d["id"]),
        "channel": d.get("uploader") or d.get("channel") or "",
        "duration": int(d.get("duration") or 0),
        "url": d.get("webpage_url", url),
    }


# ── transcript sources ─────────────────────────────────────────────────────────
def fetch_subs(url, scratch, lang):
    """Try manual subs, then auto-captions. Returns (vtt_path, kind) or (None, None)."""
    for auto, kind in ((False, "subtitles"), (True, "auto-captions")):
        for f in scratch.glob("*.vtt"):
            f.unlink()
        cmd = [
            "yt-dlp", "--no-warnings", "--skip-download",
            "--sub-langs", f"{lang}.*,{lang}", "--sub-format", "vtt",
            "--write-auto-subs" if auto else "--write-subs",
            "-o", str(scratch / "%(id)s"), url,
        ]
        run(cmd, capture_output=True, text=True)
        vtts = sorted(scratch.glob("*.vtt"))
        if vtts:
            info(f"using {kind}: {vtts[0].name}")
            return vtts[0], kind
    return None, None


LIB_ENV = {**os.environ, "LD_LIBRARY_PATH":
           str(Path.home() / ".local/lib") + ":" + os.environ.get("LD_LIBRARY_PATH", "")}


def transcribe_whisper(url, scratch, lang, model):
    need("whisper")
    if not Path(model).exists():
        die(f"whisper model not found: {model}")
    wav16 = _audio16(url, scratch)
    info("transcribing with whisper.cpp (this can take a while)...")
    p = run(
        ["whisper", "-m", model, "-f", str(wav16), "-l", lang, "-ovtt",
         "-of", str(scratch / "whisper")],
        capture_output=True, text=True,
    )
    if p.returncode != 0:
        die(f"whisper failed\n{p.stderr.strip()}")
    return parse_vtt(scratch / "whisper.vtt"), "whisper"


def _audio16(url, scratch):
    """Download audio and resample to 16kHz mono wav. Returns the wav path."""
    need("ffmpeg")
    info("no subtitles — downloading audio...")
    p = run(
        ["yt-dlp", "--no-warnings", "-x", "--audio-format", "wav",
         "-o", str(scratch / "audio.%(ext)s"), url],
        capture_output=True, text=True,
    )
    if p.returncode != 0:
        die(f"audio download failed\n{p.stderr.strip()}")
    raw = next(scratch.glob("audio.*"))
    wav16 = scratch / "audio16.wav"
    info("resampling to 16kHz mono...")
    run(["ffmpeg", "-y", "-i", str(raw), "-ar", "16000", "-ac", "1", str(wav16)],
        capture_output=True)
    return wav16


# Parakeet token line, e.g.:  [ 0] id= 5831 ... t0= 416 ... word_start=true "▁This"
PK_TOK = re.compile(r'^\s*\[\s*\d+\]\s+id=.*?\bt0=\s*(\d+)\b.*?word_start=(true|false)\s+"(.*)"\s*$')


def _parakeet_cues(stderr_text, max_words=14):
    """Parse parakeet-cli --print-segments token lines into [(start_sec, text)] cues.
    Tokens carry t0 in 10ms mel frames; ▁ marks a word boundary."""
    words, cur, cur_t = [], "", None
    for line in stderr_text.splitlines():
        m = PK_TOK.match(line)
        if not m:
            continue
        t0 = int(m.group(1)) * 0.01
        raw = m.group(3)
        if m.group(2) == "true" and raw.startswith("▁"):
            if cur.strip():
                words.append((cur_t, cur.strip()))
            cur, cur_t = raw.replace("▁", " "), t0
        else:
            cur_t = t0 if cur_t is None else cur_t
            cur += raw.replace("▁", " ")
    if cur.strip():
        words.append((cur_t, cur.strip()))

    cues, buf, t0 = [], [], None
    for t, w in words:
        if not buf:
            t0 = t
        buf.append(w)
        if w.endswith((".", "?", "!")) or len(buf) >= max_words:
            cues.append((t0, " ".join(buf)))
            buf = []
    if buf:
        cues.append((t0, " ".join(buf)))
    return cues


def transcribe_parakeet(url, scratch, model):
    need("parakeet-cli")
    if not Path(model).exists():
        die(f"parakeet model not found: {model}")
    wav16 = _audio16(url, scratch)
    info("transcribing with parakeet (English)...")
    p = run(["parakeet-cli", "-m", model, "-f", str(wav16), "--print-segments"],
            capture_output=True, text=True, env=LIB_ENV)
    if p.returncode != 0:
        die(f"parakeet failed\n{p.stderr.strip()}")
    cues = _parakeet_cues(p.stderr)
    if not cues:
        die("parakeet produced no tokens")
    return cues, "parakeet"


# ── vtt parsing ─────────────────────────────────────────────────────────────────
TS = re.compile(r"(\d{2}):(\d{2}):(\d{2})\.\d{3}\s+-->\s+(\d{2}):(\d{2}):(\d{2})")
TAG = re.compile(r"<[^>]+>")
INLINE_TS = re.compile(r"<\d{2}:\d{2}:\d{2}\.\d{3}>")  # YouTube rolling-caption word timing


def _secs(h, m, s):
    return int(h) * 3600 + int(m) * 60 + int(s)


def parse_vtt(path):
    """Parse VTT into [(start_seconds, text)], collapsing rolling auto-caption dupes."""
    raw = path.read_text(encoding="utf-8", errors="replace")
    # YouTube rolling auto-captions repeat the previous line as plain "carryover" text
    # and put the genuinely new words on a line carrying inline <hh:mm:ss.mmm> tags.
    # In that format, keep only the tag-bearing lines; manual/whisper VTTs have no tags.
    auto = bool(INLINE_TS.search(raw))
    cues = []
    start = None
    buf = []
    for line in raw.splitlines():
        m = TS.match(line.strip())
        if m:
            if start is not None and buf:
                cues.append((start, " ".join(buf)))
            start = _secs(*m.groups()[:3])
            buf = []
        elif start is not None and line.strip() and "-->" not in line:
            if auto and not INLINE_TS.search(line):
                continue
            txt = TAG.sub("", line).replace("&nbsp;", " ")
            txt = re.sub(r"\s+", " ", txt).strip()
            if txt:
                buf.append(txt)
    if start is not None and buf:
        cues.append((start, " ".join(buf)))

    out = []
    for t, txt in cues:
        if out:
            prev = out[-1][1]
            if txt == prev or txt in prev:
                continue
            if prev in txt:               # rolling caption grew — replace
                out[-1] = (out[-1][0], txt)
                continue
        out.append((t, txt))
    return out


def hms(sec):
    sec = int(sec)
    return f"{sec // 3600:02d}:{(sec % 3600) // 60:02d}:{sec % 60:02d}"


def render_transcript(cues):
    return "\n".join(f"[{hms(t)}] {txt}" for t, txt in cues)


# ── notes ───────────────────────────────────────────────────────────────────────
NOTE_PROMPT = """You are taking research notes on a YouTube talk for someone who wants \
the substance without rewatching. Below is a timestamped transcript.

Write notes as clean Markdown with these sections:
- **TL;DR** — 2-3 sentences.
- **Key points** — bulleted, the actual claims/arguments made.
- **Notable moments** — a few bullets, each prefixed with its [HH:MM:SS] timestamp.
- **Terms & references** — people, tools, papers, or concepts named (skip if none).
- **Open questions / what's unresolved** — skip if none.

Ground every note in the transcript; do not invent claims. Be concise. \
Do not use em dashes or arrow characters. Output only the Markdown notes, no preamble."""


def make_notes(transcript):
    need("claude")
    info("generating notes with claude...")
    p = run(["claude", "-p", NOTE_PROMPT], input=transcript,
            capture_output=True, text=True)
    if p.returncode != 0 or not p.stdout.strip():
        info(f"claude failed; skipping notes\n{p.stderr.strip()}")
        return None
    return p.stdout.strip()


# ── assembly ────────────────────────────────────────────────────────────────────
def slugify(s):
    s = re.sub(r"[^\w\s-]", "", s.lower()).strip()
    return re.sub(r"[\s_-]+", "-", s)[:60] or "video"


def yaml_escape(s):
    return '"' + str(s).replace('"', '\\"') + '"'


def build_md(meta, source, transcript, notes):
    fm = [
        "---",
        f"id: {meta['id']}",
        f"title: {yaml_escape(meta['title'])}",
        f"channel: {yaml_escape(meta['channel'])}",
        f"url: {meta['url']}",
        f"duration: {hms(meta['duration'])}",
        f"transcript_source: {source}",
        f"created: '{date.today().isoformat()}'",
        "---",
        "",
        f"# {meta['title']}",
        "",
        f"{meta['channel']}  ·  {meta['url']}",
        "",
    ]
    body = []
    if notes:
        body += ["## Notes", "", notes, ""]
    body += ["## Transcript", "", transcript, ""]
    return "\n".join(fm + body)


def main():
    ap = argparse.ArgumentParser(
        prog="ytnote",
        description="YouTube -> timestamped transcript + AI research notes.",
    )
    ap.add_argument("url", help="YouTube URL or video id")
    ap.add_argument("--dir", default=os.environ.get("YTNOTE_DIR", os.getcwd()),
                    help="output dir (default: $YTNOTE_DIR or cwd)")
    ap.add_argument("--lang", default="en", help="transcript language (default: en)")
    ap.add_argument("--no-notes", action="store_true", help="transcript only, skip claude")
    ap.add_argument("--parakeet", action="store_true",
                    help="force local Parakeet transcription, ignore YouTube subtitles")
    ap.add_argument("--whisper", action="store_true",
                    help="use whisper.cpp instead of Parakeet for local transcription")
    ap.add_argument("--model", default=None,
                    help="override the local model path (whisper or parakeet)")
    args = ap.parse_args()

    need("yt-dlp")
    meta = fetch_meta(args.url)
    outdir = Path(args.dir).expanduser()
    outdir.mkdir(parents=True, exist_ok=True)

    with tempfile.TemporaryDirectory(prefix=f"ytnote-{meta['id']}-") as tmp:
        scratch = Path(tmp)
        cues, source = None, None
        force_local = args.whisper or args.parakeet
        if not force_local:
            vtt, source = fetch_subs(meta["url"], scratch, args.lang)
            if vtt is not None:
                cues = parse_vtt(vtt)
        if cues is None:
            if args.whisper:
                cues, source = transcribe_whisper(
                    meta["url"], scratch, args.lang, args.model or WHISPER_MODEL)
            else:
                cues, source = transcribe_parakeet(
                    meta["url"], scratch, args.model or PARAKEET_MODEL)
        if not cues:
            die("transcript came back empty")
        transcript = render_transcript(cues)

    notes = None if args.no_notes else make_notes(transcript)

    out = outdir / f"{slugify(meta['title'])}-{meta['id']}.md"
    out.write_text(build_md(meta, source, transcript, notes), encoding="utf-8")
    info(f"wrote {out}")
    print(out)


if __name__ == "__main__":
    main()
